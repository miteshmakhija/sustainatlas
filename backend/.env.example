# ---- SustainAtlas enquiry backend configuration ----
# Copy this file to .env and fill in real values.

# SMTP server (example shows Gmail; use your provider's settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# SMTP login credentials.
# For Gmail, create an App Password (not your normal password).
SMTP_USER=your-smtp-username@example.com
SMTP_PASSWORD=your-app-password

# Where enquiry emails are sent / shown as sender
MAIL_FROM=no-reply@sustainatlas.com
MAIL_TO=connect@sustainatlas.com

# Frontend origins allowed to call the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# NOTE: If SMTP_USER / SMTP_PASSWORD are left blank, the server runs in
# "dry-run" mode — the form works and the enquiry is logged to the console
# instead of being emailed. Fill these in to actually deliver mail.
